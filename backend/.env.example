APP_NAME=SemanticSQL API
ENVIRONMENT=development
API_V1_PREFIX=/api/v1
# Optional. If omitted, the backend uses local SQLite at backend/semanticsql.db.
# DATABASE_URL=mysql+pymysql://user:password@localhost:3306/semanticsql
REDIS_URL=redis://localhost:6379/0
SEMANTIC_CACHE_SIMILARITY_THRESHOLD=0.9
SEMANTIC_CACHE_MODEL_NAME=all-MiniLM-L6-v2
LLM_MODEL=llama3.1:8b
BACKEND_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174
